# MongoDB connection string
MONGO_URI=mongodb://localhost:27017/sentinel

# JWT Secret
JWT_SECRET=your_jwt_secret_here

# Algorand Treasury Wallet (receives Studio subscription ALGO)
TREASURY_WALLET=your_algorand_address_here
RECEIVER_WALLET=your_algorand_address_here

# Creator withdrawals — never commit. Fund treasury with TestNet ALGO.
# Legacy Pera account: 25-word Algorand mnemonic. Pera Universal Wallet: 24-word BIP-39 phrase.
# PLATFORM_MNEMONIC=word1 word2 ... word24
# PLATFORM_HD_ACCOUNT=0
# PLATFORM_HD_INDEX=0

# Redis URL for background publishing queue
REDIS_URL=redis://localhost:6379

# Encryption key (exactly 32 characters)
ENCRYPTION_KEY=your_32_char_encryption_key_here

# CORS — comma-separated SPA origins (Render: your custom domain + onrender URL)
FRONTEND_URL=http://localhost:5173
FRONTEND_ORIGIN=http://localhost:5173
# CORS_ALLOWED_ORIGINS=https://sentinalai.dev,https://www.sentinalai.dev

# Workflow Studio (optional)
X402_CONTRACT_ADDRESS=

# ClipCraft — AI Studio clip pipeline (see backend/src/studio/clipcraft/.env.example)
CLIPCRAFT_ENABLED=true
CLIPCRAFT_PROVIDER_MODE=mock
CLIPCRAFT_MAX_CONCURRENT_JOBS=4
CLIPCRAFT_JOB_TIMEOUT_MS=300000
CLIPCRAFT_MAX_RETRIES=3
CLIPCRAFT_RETRY_BACKOFF_MS=2000
CLIPCRAFT_CREDITS_PER_PACK=1.5
CLIPCRAFT_BULK_PACK_THRESHOLD=10
CLIPCRAFT_BULK_PACK_TOTAL_CREDITS=12
CLIPCRAFT_VIRAL_SURCHARGE_PER_PACK=0.2
CLIPCRAFT_JOB_QUEUE_ADAPTER=memory
CLIPCRAFT_PROGRESS_ADAPTER=memory
CLIPCRAFT_RATE_LIMIT_PER_MIN=30
CLIPCRAFT_IDEMPOTENCY_TTL_MS=86400000
CLIPCRAFT_SHUTDOWN_TIMEOUT_MS=30000

# Advanced Prompt Generator (required for /api/studio/prompt/*)
# Create key: https://aistudio.google.com/apikey
GOOGLE_API_KEY=your_gemini_api_key_here
# Optional: gemini-2.5-flash | gemini-2.0-flash | gemini-1.5-flash
# GEMINI_MODEL=gemini-2.5-flash
# Viral Thumbnail image preview (optional override)
# GEMINI_IMAGE_MODEL=gemini-2.5-flash-image
# Creative Workflow: POST /api/studio/workflow/creative (prompt → image / thumbnail)

# Agentic Pipeline + Workflow Studio agentic nodes
#
# Gemini API (text, TTS, eval, memory, image fallback) — uses GOOGLE_API_KEY above.
#
# Vertex AI (Imagen + Veo) — use ONE of these auth methods:
# 1) Service account JSON (recommended for Veo):
# GOOGLE_CLOUD_PROJECT=your_gcp_project_id
# GOOGLE_APPLICATION_CREDENTIALS=../your-service-account.json
# 2) Vertex AI Studio / express mode API key:
# VERTEX_API_KEY=your_vertex_api_key_here
# VERTEX_LOCATION=us-central1
#
# Images in workflows: default = Gemini (GOOGLE_API_KEY). Imagen only if enabled:
# VERTEX_IMAGEN_ENABLED=false
# VERTEX_IMAGEN_MODEL=imagen-3.0-generate-002
#
# Video (Veo): requires GCS bucket + project allowlist (Model Garden → Veo → Request access)
# GCS_ASSETS_BUCKET=your-bucket   (Veo writes to gs://bucket/sentinal/veo-output/)
# VEO_MODEL_IDS=veo-3.1-fast-generate-001,veo-3.0-fast-generate-001,veo-2.0-generate-001
#
# IAM on service account: roles/aiplatform.user (Vertex AI User) + Storage Object Admin on bucket
# Enable APIs: Vertex AI API, Cloud Storage API
#
# GCS — all generated images/audio/video (recommended for production)
# Create bucket in same project; grant service account Storage Object Admin
# GCS_ASSETS_BUCKET=your-bucket-name
# GCS_ASSET_PREFIX=sentinal
# GCS_SIGNED_URL_TTL_SEC=3600

# CODE_SANDBOX=docker
# PIPELINE_OUTPUT_DIR=./outputs/pipeline
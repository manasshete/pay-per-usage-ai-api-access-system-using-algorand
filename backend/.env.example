# MongoDB connection string
MONGO_URI=mongodb://localhost:27017/sentinel

# JWT Secret
JWT_SECRET=your_jwt_secret_here

# Algorand Treasury Wallet
TREASURY_WALLET=your_algorand_address_here

# Redis URL for background publishing queue
REDIS_URL=redis://localhost:6379

# Encryption key (exactly 32 characters)
ENCRYPTION_KEY=your_32_char_encryption_key_here

# CORS — comma-separated SPA origins (Render: your custom domain + onrender URL)
FRONTEND_URL=http://localhost:5173
FRONTEND_ORIGIN=http://localhost:5173
# CORS_ALLOWED_ORIGINS=https://sentinalai.dev,https://www.sentinalai.dev

# Workflow Studio (optional)
X402_CONTRACT_ADDRESS=

# ClipCraft — AI Studio clip pipeline (see backend/src/studio/clipcraft/.env.example)
CLIPCRAFT_ENABLED=true
CLIPCRAFT_PROVIDER_MODE=mock
CLIPCRAFT_MAX_CONCURRENT_JOBS=4
CLIPCRAFT_JOB_TIMEOUT_MS=300000
CLIPCRAFT_MAX_RETRIES=3
CLIPCRAFT_RETRY_BACKOFF_MS=2000
CLIPCRAFT_CREDITS_PER_PACK=1.5
CLIPCRAFT_BULK_PACK_THRESHOLD=10
CLIPCRAFT_BULK_PACK_TOTAL_CREDITS=12
CLIPCRAFT_VIRAL_SURCHARGE_PER_PACK=0.2
CLIPCRAFT_JOB_QUEUE_ADAPTER=memory
CLIPCRAFT_PROGRESS_ADAPTER=memory
CLIPCRAFT_RATE_LIMIT_PER_MIN=30
CLIPCRAFT_IDEMPOTENCY_TTL_MS=86400000
CLIPCRAFT_SHUTDOWN_TIMEOUT_MS=30000
# ClipCraft — AI Studio (backend/src/studio/clipcraft)
# Copy keys into backend/.env

CLIPCRAFT_ENABLED=true
CLIPCRAFT_PROVIDER_MODE=mock
CLIPCRAFT_MAX_CONCURRENT_JOBS=4
CLIPCRAFT_JOB_TIMEOUT_MS=300000
CLIPCRAFT_MAX_RETRIES=3
CLIPCRAFT_RETRY_BACKOFF_MS=2000

# Credits pricing (override defaults)
CLIPCRAFT_CREDITS_PER_PACK=1.5
CLIPCRAFT_BULK_PACK_THRESHOLD=10
CLIPCRAFT_BULK_PACK_TOTAL_CREDITS=12
CLIPCRAFT_VIRAL_SURCHARGE_PER_PACK=0.2

# External provider endpoints (live mode)
CLIPCRAFT_TRANSCRIPT_PROVIDER_URL=
CLIPCRAFT_TRANSCRIPT_API_KEY=
CLIPCRAFT_AI_ANALYZER_URL=
CLIPCRAFT_AI_ANALYZER_API_KEY=
CLIPCRAFT_COPY_GENERATOR_URL=
CLIPCRAFT_COPY_GENERATOR_API_KEY=
CLIPCRAFT_EXPORT_PROVIDER_URL=
CLIPCRAFT_EXPORT_API_KEY=
CLIPCRAFT_SCHEDULER_PROVIDER_URL=
CLIPCRAFT_SCHEDULER_API_KEY=

# Orchestration adapters
CLIPCRAFT_JOB_QUEUE_ADAPTER=memory
CLIPCRAFT_PROGRESS_ADAPTER=memory
CLIPCRAFT_WEBHOOK_SECRET=

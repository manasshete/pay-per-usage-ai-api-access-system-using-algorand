NODE_ENV=development
PORT=4000
MONGO_URI=mongodb://localhost:27017/sentinel-chat
JWT_SECRET=your-shared-jwt-secret-from-sentinel-backend
SENTINEL_API_URL=http://localhost:5000
ALLOWED_ORIGIN=http://localhost:5555

# Firebase Admin configuration (optional for Google sign-in validation)
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_CLIENT_EMAIL=your-service-account@project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

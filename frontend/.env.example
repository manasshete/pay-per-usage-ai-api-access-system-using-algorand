# Local backend (must match PORT in backend/.env)
VITE_API_URL=http://localhost:5001

# Algorand node (testnet default). Must match the network where users fund the burner wallet.
# VITE_ALGOD_SERVER=https://testnet-api.algonode.cloud

# Production — custom domain https://sentinalai.dev (frontend on Render)
# Point VITE_API_URL at your BACKEND Render service (not the .dev domain unless API is on api.sentinalai.dev)
# VITE_API_URL=https://sentinal-z3ue.onrender.com

# Optional: public site URL for blog links (defaults to window.location.origin)
# VITE_PUBLIC_SITE_URL=https://sentinalai.dev

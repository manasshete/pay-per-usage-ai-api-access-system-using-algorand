# --- Local dev (npm run dev) ---
# Leave VITE_API_URL unset — the app calls /api on localhost:5173 and Vite proxies to your backend.
# VITE_PROXY_TARGET=http://localhost:5000
# To hit Render API while developing locally (still no CORS):
# VITE_PROXY_TARGET=https://sentinal-z3ue.onrender.com

# Do NOT set VITE_API_URL to sentinalai.dev or sentinalai.com in dev (those are the website, not the API).

# --- Production build (Render / sentinalai.dev frontend) ---
VITE_API_URL=https://sentinal-z3ue.onrender.com

# Algorand node (testnet default). Used for wallet signing and Studio payments.
# VITE_ALGORAND_NODE=https://testnet-api.algonode.cloud

# Optional: public site URL for blog links (defaults to window.location.origin)
# VITE_PUBLIC_SITE_URL=https://sentinalai.dev

# Prompt Generator uses backend GOOGLE_API_KEY (see backend/.env.example) + Studio subscription quotas

# Optional: override payment destination (defaults to backend RECEIVER_WALLET via /api/public/network)
# VITE_RECEIVER_WALLET=your_algorand_address_here

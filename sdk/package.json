{
  "name": "@sentinalapi/sdk",
  "version": "1.0.0",
  "description": "Official JavaScript/TypeScript SDK for the Sentinel pay-per-use AI API marketplace on Algorand",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist",
    "README.md",
    "docs"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "prepublishOnly": "npm run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "typecheck": "tsc --noEmit"
  },
  "publishConfig": {
    "access": "public"
  },
  "author": "Sentinel AI Team <wesentinal@gmail.com>",
  "homepage": "https://github.com/lathi-aayush/pay-per-usage-ai-api-access-system-using-algorand/tree/main/sdk",
  "repository": {
    "type": "git",
    "url": "https://github.com/lathi-aayush/pay-per-usage-ai-api-access-system-using-algorand.git",
    "directory": "sdk"
  },
  "bugs": {
    "url": "https://github.com/lathi-aayush/pay-per-usage-ai-api-access-system-using-algorand/issues",
    "email": "wesentinal@gmail.com"
  },
  "dependencies": {
    "algosdk": "^3.5.2"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "keywords": [
    "sentinel",
    "algorand",
    "ai",
    "pay-per-use",
    "api",
    "sdk",
    "blockchain",
    "llm",
    "groq",
    "openai"
  ]
}
